{
  "expo": {
    "name": "SnowLog",
    "slug": "snowlog",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "snowlog",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "スキー動画のインポートとサムネイル生成のため、フォトライブラリへのアクセスが必要です。",
        "NSPhotoLibraryAddUsageDescription": "サムネイル画像の保存のため、フォトライブラリへの書き込みが必要です。",
        "CFBundleDevelopmentRegion": "ja",
        "CFBundleLocalizations": [
          "ja",
          "en"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "photos-redirect"
        ]
      },
      "bundleIdentifier": "com.kmch4n.snowlog"
    },
    "android": {
      "package": "com.kmch4n.snowlog"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A3A5C",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "スキー動画のインポートとサムネイル生成のため、フォトライブラリへのアクセスが必要です。",
          "savePhotosPermission": "サムネイル画像の保存のため、フォトライブラリへの書き込みが必要です。",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-sqlite",
      "expo-video",
      "expo-sharing",
      "expo-web-browser",
      "expo-image",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "ja",
              "en"
            ],
            "android": [
              "ja",
              "en"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f0e53dc0-a550-4f0b-b2b3-b9ae099c1362"
      }
    }
  }
}
