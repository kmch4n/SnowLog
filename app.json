{
  "expo": {
    "name": "SnowLog",
    "slug": "snowlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "snowlog",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "スキー動画のインポートとサムネイル生成のため、フォトライブラリへのアクセスが必要です。",
        "NSPhotoLibraryAddUsageDescription": "サムネイル画像の保存のため、フォトライブラリへの書き込みが必要です。",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.kmch4n.snowlog"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A3A5C",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "スキー動画のインポートとサムネイル生成のため、フォトライブラリへのアクセスが必要です。",
          "savePhotosPermission": "サムネイル画像の保存のため、フォトライブラリへの書き込みが必要です。",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-sqlite",
      "expo-video",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f0e53dc0-a550-4f0b-b2b3-b9ae099c1362"
      }
    }
  }
}
