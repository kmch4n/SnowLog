---
import { localePaths } from "../i18n";
import "../styles/global.css";

const target = localePaths.ja;
---

<!doctype html>
<html lang="ja">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta http-equiv="refresh" content={`0; url=${target}`} />
        <link rel="canonical" href={target} />
        <script is:inline>
            const language = navigator.language || "";
            const languages = navigator.languages || [language];
            const prefersJapanese = languages.some((item) => item.toLowerCase().startsWith("ja"));
            window.location.replace(prefersJapanese ? "/ja/" : "/en/");
        </script>
        <title>SnowLog</title>
    </head>
    <body class="gateway-page">
        <main class="gateway-card">
            <img src="/images/icon.png" alt="" width="72" height="72" />
            <h1>SnowLog</h1>
            <p>ページを移動しています。</p>
            <div class="gateway-links">
                <a href="/ja/">日本語</a>
                <a href="/en/">English</a>
            </div>
        </main>
    </body>
</html>
