---
import type { PrivacyPanelContent } from "../i18n";

interface Props {
    appStoreUrl: string;
    content: PrivacyPanelContent;
}

const { appStoreUrl, content } = Astro.props;
const titleLines = content.title.split("\n");
const bodyLines = content.body.split("\n");
---

<section class="section privacy-section" aria-labelledby="privacy-title">
    <div class="privacy-panel">
        <div class="privacy-copy">
            <p class="eyebrow">{content.eyebrow}</p>
            <h2 id="privacy-title">
                {titleLines.map((line) => <span>{line}</span>)}
            </h2>
            <p>
                {bodyLines.map((line) => <span>{line}</span>)}
            </p>
            <a class="text-link privacy-cta" href={appStoreUrl}>
                <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18">
                    <path
                        fill="currentColor"
                        d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 8.9 7.31c1.31.07 2.22.72 2.98.78 1.13-.23 2.22-.89 3.54-.8 1.58.13 2.77.75 3.56 1.91-3.13 1.88-2.39 6.03.48 7.18-.57 1.5-1.31 2.99-2.41 3.9ZM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25Z"
                    />
                </svg>
                <span>{content.cta}</span>
            </a>
        </div>
        <ul class="privacy-list" aria-label={content.listAria}>
            {
                content.items.map((item) => (
                    <li>
                        <span class="privacy-list-icon" aria-hidden="true"></span>
                        <span>{item}</span>
                    </li>
                ))
            }
        </ul>
    </div>
</section>
