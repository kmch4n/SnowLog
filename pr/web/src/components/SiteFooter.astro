---
import ContactReveal from "./ContactReveal.astro";
import { githubUrl, privacyPaths, type FooterContent, type Locale } from "../i18n";

interface Props {
    appStoreUrl: string;
    content: FooterContent;
    locale: Locale;
}

const { appStoreUrl, content, locale } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
    <div class="footer-brand">
        <img src="/images/icon.png" alt="" />
        <span>SnowLog</span>
    </div>
    <nav aria-label={content.ariaLabel}>
        <a class="footer-store" href={appStoreUrl}>
            <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18">
                <path
                    fill="currentColor"
                    d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 8.9 7.31c1.31.07 2.22.72 2.98.78 1.13-.23 2.22-.89 3.54-.8 1.58.13 2.77.75 3.56 1.91-3.13 1.88-2.39 6.03.48 7.18-.57 1.5-1.31 2.99-2.41 3.9ZM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25Z"
                />
            </svg>
            <span>{content.appStore}</span>
        </a>
        <a class="footer-github" href={githubUrl}>
            <svg aria-hidden="true" viewBox="0 0 16 16" width="18" height="18">
                <path
                    fill="currentColor"
                    d="M8 0C3.58 0 0 3.67 0 8.2c0 3.62 2.29 6.69 5.47 7.78.4.08.55-.18.55-.4 0-.2-.01-.84-.01-1.52-2.01.38-2.53-.5-2.69-.96-.09-.24-.48-.96-.82-1.16-.28-.16-.68-.55-.01-.56.63-.01 1.08.59 1.23.84.72 1.24 1.87.89 2.33.68.07-.53.28-.89.51-1.09-1.78-.21-3.64-.91-3.64-4.03 0-.89.31-1.62.82-2.19-.08-.21-.36-1.04.08-2.16 0 0 .67-.22 2.2.84A7.43 7.43 0 0 1 8 4c.68 0 1.36.09 2 .27 1.53-1.06 2.2-.84 2.2-.84.44 1.12.16 1.95.08 2.16.51.57.82 1.3.82 2.19 0 3.13-1.87 3.82-3.65 4.03.29.26.54.75.54 1.51 0 1.09-.01 1.97-.01 2.24 0 .22.15.48.55.4A8.18 8.18 0 0 0 16 8.2C16 3.67 12.42 0 8 0Z"
                />
            </svg>
            <span>{content.github}</span>
        </a>
        <a href={privacyPaths[locale]}>{content.privacy}</a>
        <ContactReveal label={content.support} className="footer-contact" />
    </nav>
    <p class="footer-copyright">Copyright © {currentYear} Kotaro Sasagawa. All rights reserved.</p>
</footer>
